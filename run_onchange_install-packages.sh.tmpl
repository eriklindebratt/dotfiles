#!/bin/bash
# Install Homebrew formulae/casks from the Brewfile. Re-runs whenever the Brewfile
# changes (tracked by the hash line below). brew shellenv guarantees brew is on PATH
# even on a fresh machine; the absolute path is required since PATH isn't set up yet.
eval "$(/opt/homebrew/bin/brew shellenv)"
# hash: {{ include "Brewfile" | sha256sum }}
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
