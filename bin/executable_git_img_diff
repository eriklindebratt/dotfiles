#!/bin/bash

set -e

if [[ -f "$1" ]] && [[ -f "$2" ]]; then
  echo "Diffing:"
  echo "  - $2"
  echo "  - $1"
  compare "$2" "$1" png:- | montage -geometry +4+4 "$2" - "$1" png:- | timg -pk -
else
  if [[ -f "$1" ]]; then
    echo "+ Image Added: $1"
    timg -pk "$1"
  else
    echo "- Image Removed: $1"
    timg -pk "$2"
  fi
fi
