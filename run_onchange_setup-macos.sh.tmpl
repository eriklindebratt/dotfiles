#!/bin/bash
# Apply macOS defaults from .macos. Re-runs only when .macos changes (hash line below).
# .macos issues sudo commands, so confirm + prime sudo up front, and guard for a TTY so a
# non-interactive apply (CI, piped) skips rather than hanging mid-run.
# hash: {{ include ".macos" | sha256sum }}

if [ ! -t 0 ]; then
  echo "No TTY; skipping macOS defaults (.macos). Run it manually to apply."
  exit 0
fi

read -r -p "Apply macOS defaults from .macos now? (y/N) " response
case "$response" in
  [yY][eE][sS]|[yY]) ;;
  *) echo "Skipping macOS defaults."; exit 0 ;;
esac

# Prime sudo up front so .macos's sudo calls don't prompt partway through.
sudo -v

source "{{ .chezmoi.sourceDir }}/.macos"

echo "Done. Some macOS changes may require a logout or restart to take effect."
